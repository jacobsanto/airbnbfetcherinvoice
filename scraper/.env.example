NODE_ENV=development

# Supabase (service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Must match backend ENCRYPTION_KEY exactly
ENCRYPTION_KEY=your-64-char-hex-key

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Backend API for OTP polling
BACKEND_API_URL=http://localhost:3001/v1
INTERNAL_API_SECRET=your-random-secret

# Puppeteer
PUPPETEER_HEADLESS=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium  # Uncomment for Docker
PUPPETEER_TIMEOUT=30000

# Worker concurrency
SCRAPER_CONCURRENCY=2
